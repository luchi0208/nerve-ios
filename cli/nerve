#!/usr/bin/env bash
set -euo pipefail

# Nerve CLI — Launch iOS apps with Nerve framework injected
# Usage:
#   nerve launch --scheme MyApp --simulator "iPhone 16 Pro"
#   nerve mcp    (start MCP server)
#   nerve status (show connected targets)

NERVE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
NERVE_BUILD_DIR="${NERVE_DIR}/.build/nerve-dylib"
PORT_DIR="/tmp/nerve-ports"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() { echo -e "${GREEN}[nerve]${NC} $1"; }
warn() { echo -e "${YELLOW}[nerve]${NC} $1"; }
err() { echo -e "${RED}[nerve]${NC} $1" >&2; }

# --- Commands ---

cmd_launch() {
    local scheme=""
    local simulator=""
    local workspace=""
    local project=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scheme) scheme="$2"; shift 2 ;;
            --simulator) simulator="$2"; shift 2 ;;
            --workspace) workspace="$2"; shift 2 ;;
            --project) project="$2"; shift 2 ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done

    if [[ -z "$scheme" ]]; then
        err "Missing --scheme. Usage: nerve launch --scheme MyApp --simulator \"iPhone 16 Pro\""
        exit 1
    fi

    # Default simulator
    if [[ -z "$simulator" ]]; then
        simulator="iPhone 16 Pro"
    fi

    # Find simulator UDID
    log "Finding simulator: $simulator"
    local udid
    udid=$(xcrun simctl list devices available -j | \
        python3 -c "
import json, sys
data = json.load(sys.stdin)
for runtime, devices in data.get('devices', {}).items():
    for d in devices:
        if d['name'] == '$simulator' and d['state'] != 'Shutdown':
            print(d['udid']); sys.exit(0)
for runtime, devices in data.get('devices', {}).items():
    for d in devices:
        if d['name'] == '$simulator':
            print(d['udid']); sys.exit(0)
print(''); sys.exit(1)
" 2>/dev/null) || true

    if [[ -z "$udid" ]]; then
        err "Simulator '$simulator' not found. Available simulators:"
        xcrun simctl list devices available | grep -E "iPhone|iPad" | head -10
        exit 1
    fi

    log "Simulator UDID: $udid"

    # Boot simulator if needed
    local state
    state=$(xcrun simctl list devices -j | python3 -c "
import json, sys
data = json.load(sys.stdin)
for runtime, devices in data.get('devices', {}).items():
    for d in devices:
        if d['udid'] == '$udid':
            print(d['state']); sys.exit(0)
" 2>/dev/null)

    if [[ "$state" != "Booted" ]]; then
        log "Booting simulator..."
        xcrun simctl boot "$udid" 2>/dev/null || true
        # Open Simulator.app
        open -a Simulator --args -CurrentDeviceUDID "$udid" 2>/dev/null || true
        sleep 2
    fi

    # Build the app
    log "Building $scheme for simulator..."
    local build_args=(-scheme "$scheme" -sdk iphonesimulator -configuration Debug -derivedDataPath "${NERVE_DIR}/.build/DerivedData")

    if [[ -n "$workspace" ]]; then
        build_args=(-workspace "$workspace" "${build_args[@]}")
    elif [[ -n "$project" ]]; then
        build_args=(-project "$project" "${build_args[@]}")
    fi

    xcodebuild build "${build_args[@]}" -quiet 2>&1 | tail -5

    # Find the built app
    local app_path
    app_path=$(find "${NERVE_DIR}/.build/DerivedData/Build/Products/Debug-iphonesimulator" -name "*.app" -maxdepth 1 | head -1)

    if [[ -z "$app_path" ]]; then
        err "Could not find built .app bundle"
        exit 1
    fi

    local bundle_id
    bundle_id=$(/usr/libexec/PlistBuddy -c "Print :CFBundleIdentifier" "$app_path/Info.plist")

    log "App: $bundle_id ($app_path)"

    # Install the app
    log "Installing on simulator..."
    xcrun simctl install "$udid" "$app_path"

    # Clean up old port file
    mkdir -p "$PORT_DIR"
    rm -f "$PORT_DIR/$udid-$bundle_id.json"

    # Launch
    log "Launching..."
    xcrun simctl launch "$udid" "$bundle_id"

    # Wait for Nerve to be ready
    log "Waiting for Nerve WebSocket server..."
    local attempts=0
    while [[ ! -f "$PORT_DIR/$udid-$bundle_id.json" ]] && [[ $attempts -lt 30 ]]; do
        sleep 0.5
        attempts=$((attempts + 1))
    done

    if [[ -f "$PORT_DIR/$udid-$bundle_id.json" ]]; then
        local port
        port=$(python3 -c "import json; print(json.load(open('$PORT_DIR/$udid-$bundle_id.json'))['port'])")
        log "Nerve ready on port $port"
        log "Connect your AI agent's MCP server to ws://localhost:$port"
    else
        warn "Nerve port file not found after 15s. The app may still be starting."
        warn "Check $PORT_DIR/$udid-$bundle_id.json"
    fi
}

cmd_mcp() {
    # Start the MCP server
    local mcp_dir="${NERVE_DIR}/mcp-server"
    if [[ -f "$mcp_dir/dist/index.js" ]]; then
        exec node "$mcp_dir/dist/index.js"
    elif [[ -f "$mcp_dir/src/index.ts" ]]; then
        exec npx tsx "$mcp_dir/src/index.ts"
    else
        err "MCP server not built. Run: cd mcp-server && npm install && npm run build"
        exit 1
    fi
}

cmd_status() {
    if [[ ! -d "$PORT_DIR" ]]; then
        echo "No Nerve instances found."
        exit 0
    fi

    local found=0
    for file in "$PORT_DIR"/*.json; do
        [[ -f "$file" ]] || continue
        local info
        info=$(cat "$file")
        local pid app port platform
        pid=$(echo "$info" | python3 -c "import json,sys; print(json.load(sys.stdin)['pid'])" 2>/dev/null)
        app=$(echo "$info" | python3 -c "import json,sys; print(json.load(sys.stdin)['appName'])" 2>/dev/null)
        port=$(echo "$info" | python3 -c "import json,sys; print(json.load(sys.stdin)['port'])" 2>/dev/null)
        platform=$(echo "$info" | python3 -c "import json,sys; print(json.load(sys.stdin)['platform'])" 2>/dev/null)

        # Check if process is alive
        if kill -0 "$pid" 2>/dev/null; then
            echo "  $app ($platform) — port $port, pid $pid"
            found=$((found + 1))
        else
            rm -f "$file"
        fi
    done

    if [[ $found -eq 0 ]]; then
        echo "No Nerve instances running."
    else
        echo ""
        echo "$found instance(s) running."
    fi
}

cmd_help() {
    cat <<EOF
Nerve — Runtime inspection for iOS apps

Usage:
  nerve launch --scheme <scheme> [--simulator <name>] [--workspace <path>] [--project <path>]
    Build and launch an app with Nerve injected (simulator, zero-setup)

  nerve mcp
    Start the MCP server (for AI agent integration)

  nerve status
    Show running Nerve instances

Options:
  --scheme       Xcode scheme to build (required for launch)
  --simulator    Simulator name (default: "iPhone 16 Pro")
  --workspace    Path to .xcworkspace
  --project      Path to .xcodeproj

Examples:
  nerve launch --scheme MyApp
  nerve launch --scheme MyApp --simulator "iPhone 16" --workspace MyApp.xcworkspace
  nerve mcp
EOF
}

# --- Main ---

case "${1:-help}" in
    launch) shift; cmd_launch "$@" ;;
    mcp)    shift; cmd_mcp ;;
    status) cmd_status ;;
    help|--help|-h) cmd_help ;;
    *) err "Unknown command: $1. Run 'nerve help' for usage."; exit 1 ;;
esac
